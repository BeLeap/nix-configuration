#!/usr/bin/env /bin/bash

set -euo pipefail

name=${1:-}

if [[ -p /dev/stdin ]]; then
  name=$(cat)
fi

if [[ -z "$name" ]]; then
  name=$(wzsf)
fi

if [[ -z "$name" ]]; then
  exit 0
fi

workspace_exists=$(
  wezterm cli list --format json |
    jq -r --arg workspace "$name" 'any(.workspace == $workspace)'
)

if [[ "$workspace_exists" != "true" ]]; then
  wezterm cli spawn --new-window --workspace "$name" >/dev/null
fi

encoded_name=$(printf '%s' "$name" | base64 | tr -d '\n')
printf '\033]1337;SetUserVar=WEZTERM_WORKSPACE=%s\007' "$encoded_name"
